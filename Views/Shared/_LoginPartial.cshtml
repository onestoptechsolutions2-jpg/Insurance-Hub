@using Insurance_Hub.Models
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@if (SignInManager.IsSignedIn(User))
{
    var user = await UserManager.GetUserAsync(User);
    var label = !string.IsNullOrWhiteSpace(user?.DisplayName) ? user.DisplayName : (User.Identity?.Name ?? "");
    var initial = label.Length > 0 ? label[0].ToString().ToUpper() : "U";
    var isAdmin = User.IsInRole("Admin");

    <div class="nav-user">
        @if (isAdmin)
        {
            <a href="/admin" class="nav-admin-badge">Admin</a>
        }
        <a href="/profile" class="nav-user-avatar" title="@label">@initial</a>
        <a href="/profile" class="nav-username">@label</a>
        <form asp-area="Identity" asp-page="/Account/Logout"
              asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })"
              method="post">
            <button type="submit" class="nav-signout">Sign out</button>
        </form>
    </div>
}
else
{
    <div class="nav-auth">
        <a class="nav-auth-link" asp-area="Identity" asp-page="/Account/Login">Sign in</a>
        <a class="nav-auth-btn"  asp-area="Identity" asp-page="/Account/Register">Get started</a>
    </div>
}
