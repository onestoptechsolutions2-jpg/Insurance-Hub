<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin — Insurance Hub</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/admin.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/driver.js@1.3.1/dist/driver.css" />
</head>
<body class="admin-body" data-logged-in="true" data-is-admin="true" data-admin-page="true">

    <div class="admin-shell">

        <aside class="admin-sidebar">
            <div class="admin-brand">
                <span class="admin-brand-name">InsuranceHub</span>
                <span class="admin-brand-tag">Admin</span>
            </div>

            <nav class="admin-nav">
                <a href="/admin/quotes"    class="admin-nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Quotes"    ? "active" : "")">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                    Quotes
                </a>
                <a href="/admin/plans"     class="admin-nav-item @(ViewContext.RouteData.Values["action"]?.ToString()?.Contains("Plan")    == true ? "active" : "")">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="9" y1="3" x2="9" y2="21"/></svg>
                    Plans
                </a>
                <a href="/admin/providers" class="admin-nav-item @(ViewContext.RouteData.Values["action"]?.ToString()?.Contains("Provider") == true ? "active" : "")">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                    Providers
                </a>
                <a href="/admin/users"     class="admin-nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Users"     ? "active" : "")">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    Users
                </a>
                <a href="/admin/settings"  class="admin-nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminSettings" ? "active" : "")">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
                    Settings
                </a>
                <a href="/admin/webhooks"  class="admin-nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminWebhooks" ? "active" : "")">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 16.98h-5.99c-1.1 0-1.95.94-2.48 1.9A4 4 0 0 1 2 17c0-2.42 2.28-4.1 4.5-4.1"/><path d="M18 16.98a4 4 0 0 0 1-7.87V9a5 5 0 0 0-9.8-1.5"/><path d="M11 12v6"/><path d="m14.5 8.5-3.5 3.5-2-2"/></svg>
                    Webhooks
                </a>
                <a href="/admin/clients"   class="admin-nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminClients" ? "active" : "")">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    Clients
                </a>
                <a href="/admin/accounting" class="admin-nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminAccounting" ? "active" : "")">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                    Accounting
                </a>
            </nav>

            <button class="admin-tour-btn" data-tour="admin" title="Admin tour">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                How to use
            </button>
            <a href="/" class="admin-back-link">← Back to site</a>
        </aside>

        <div class="admin-content">
            <main class="admin-main">
                @if (TempData["Success"] is string ok)
                {
                    <div class="a-toast a-toast-ok">@ok</div>
                }
                @if (TempData["Error"] is string err)
                {
                    <div class="a-toast a-toast-err">@err</div>
                }
                @RenderBody()
            </main>
        </div>

    </div>

    <script src="~/js/site.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/driver.js@1.3.1/dist/driver.js.iife.js"></script>
    <script src="~/js/tour.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
