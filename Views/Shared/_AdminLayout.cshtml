<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin — Insurance Hub</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/admin.css" />
</head>
<body class="admin-body">

    <div class="admin-shell">

        <aside class="admin-sidebar">
            <div class="admin-brand">
                <span class="admin-brand-name">InsuranceHub</span>
                <span class="admin-brand-tag">Admin</span>
            </div>

            <nav class="admin-nav">
                <a href="/admin/quotes"    class="admin-nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Quotes"    ? "active" : "")">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                    Quotes
                </a>
                <a href="/admin/plans"     class="admin-nav-item @(ViewContext.RouteData.Values["action"]?.ToString()?.Contains("Plan")    == true ? "active" : "")">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="9" y1="3" x2="9" y2="21"/></svg>
                    Plans
                </a>
                <a href="/admin/providers" class="admin-nav-item @(ViewContext.RouteData.Values["action"]?.ToString()?.Contains("Provider") == true ? "active" : "")">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                    Providers
                </a>
                <a href="/admin/users"     class="admin-nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Users"     ? "active" : "")">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    Users
                </a>
            </nav>

            <a href="/" class="admin-back-link">← Back to site</a>
        </aside>

        <div class="admin-content">
            <main class="admin-main">
                @if (TempData["Success"] is string ok)
                {
                    <div class="a-toast a-toast-ok">@ok</div>
                }
                @if (TempData["Error"] is string err)
                {
                    <div class="a-toast a-toast-err">@err</div>
                }
                @RenderBody()
            </main>
        </div>

    </div>

    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
