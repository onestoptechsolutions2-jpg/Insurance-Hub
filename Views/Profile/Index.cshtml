@model Insurance_Hub.Models.ApplicationUser
@using Insurance_Hub.Models

@{
    Layout = "_Layout";
    var quotes   = ViewBag.Quotes   as List<QuoteRequest>  ?? new();
    var policies = ViewBag.Policies as List<UserPolicy>    ?? new();
    var today    = DateTime.UtcNow.Date;
}

@if (TempData["Success"] is string ok)
{
    <div class="s-toast s-toast-success" id="toast">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
        <span>@ok</span>
        <button class="s-toast-close" onclick="this.parentElement.remove()">×</button>
    </div>
}
@if (TempData["PolicyError"] is string pe)
{
    <div class="s-toast s-toast-error" id="toast-err">
        <span>@pe</span>
        <button class="s-toast-close" onclick="this.parentElement.remove()">×</button>
    </div>
}

<div class="profile-shell" id="profileShell">

    @* ── Identity card ─────────────────────────────────────────────────────── *@
    <div class="profile-card" id="profileCard">
        <div class="profile-avatar">@((string.IsNullOrWhiteSpace(Model.DisplayName) ? (Model.Email ?? "?") : Model.DisplayName)[0].ToString().ToUpper())</div>
        <div class="profile-card-info">
            <div class="profile-name">@(string.IsNullOrWhiteSpace(Model.DisplayName) ? Model.Email : Model.DisplayName)</div>
            <div class="profile-email">@Model.Email</div>
            <div class="profile-meta-row">
                @if (User.IsInRole("Admin")) { <span class="profile-role-badge">Admin</span> }
                <span class="profile-stat">@quotes.Count quote@(quotes.Count != 1 ? "s" : "")</span>
                <span class="profile-stat-dot">·</span>
                <span class="profile-stat">@policies.Count polic@(policies.Count != 1 ? "ies" : "y")</span>
            </div>
        </div>
    </div>

    <div class="profile-grid">

        @* ── Edit profile ─────────────────────────────────────────────────── *@
        <section class="profile-section" id="editSection">
            <h2 class="profile-section-title">Edit Profile</h2>
            <form method="post" action="/profile" class="profile-form">
                @Html.AntiForgeryToken()
                <div class="profile-field">
                    <label class="profile-label">Display Name</label>
                    <input class="profile-input" name="displayName" value="@Model.DisplayName" placeholder="Your name" maxlength="100" />
                </div>
                <div class="profile-field">
                    <label class="profile-label">Phone Number</label>
                    <input class="profile-input" name="phoneNumber" value="@Model.PhoneNumber" placeholder="+254 700 000 000" />
                </div>
                <div class="profile-field">
                    <label class="profile-label">Email</label>
                    <input class="profile-input" value="@Model.Email" disabled />
                </div>
                <button type="submit" class="profile-save-btn">Save Changes</button>
            </form>
        </section>

        @* ── Right column ─────────────────────────────────────────────────── *@
        <div class="profile-right">

            @* ── Active Policies ──────────────────────────────────────────── *@
            <section class="profile-section" id="policiesSection">
                <div class="profile-section-header">
                    <h2 class="profile-section-title" style="margin:0">My Policies</h2>
                    <button class="profile-add-btn" onclick="document.getElementById('addPolicyModal').style.display='flex'">
                        + Add Policy
                    </button>
                </div>

                @if (!policies.Any())
                {
                    <div class="profile-empty-state">
                        <div class="profile-empty-icon">🛡</div>
                        <p>No active policies added yet.</p>
                        <button class="profile-link-btn" onclick="document.getElementById('addPolicyModal').style.display='flex'">
                            Register your first policy →
                        </button>
                    </div>
                }
                else
                {
                    <div class="policies-list">
                        @foreach (var p in policies)
                        {
                            var daysLeft = (p.RenewalDate.Date - today).Days;
                            var urgency  = daysLeft <= 14 ? "renewal-urgent"
                                         : daysLeft <= 30 ? "renewal-soon"
                                         : "renewal-ok";

                            <div class="policy-row">
                                <div class="policy-row-left">
                                    <div class="policy-name">@p.PolicyName</div>
                                    <div class="policy-meta">
                                        @p.ProviderName
                                        @if (!string.IsNullOrWhiteSpace(p.InsuranceType)) { <span class="policy-type-pill">@p.InsuranceType</span> }
                                        @if (!string.IsNullOrWhiteSpace(p.PolicyNumber)) { <span class="policy-num">· @p.PolicyNumber</span> }
                                    </div>
                                    <div class="policy-premium">KES @p.MonthlyPremium.ToString("N0")/mo</div>
                                </div>
                                <div class="policy-row-right">
                                    <div class="policy-renewal @urgency">
                                        @if (daysLeft < 0)
                                        {
                                            <span>Expired @(-daysLeft)d ago</span>
                                        }
                                        else if (daysLeft == 0)
                                        {
                                            <span>Renews today!</span>
                                        }
                                        else
                                        {
                                            <span>Renews in @daysLeft day@(daysLeft != 1 ? "s" : "")</span>
                                        }
                                        <span class="policy-renewal-date">@p.RenewalDate.ToString("d MMM yyyy")</span>
                                    </div>
                                    <div class="policy-actions">
                                        <form method="post" action="/profile/policies/toggle-reminders/@p.Id" style="display:inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="policy-btn @(p.RemindersEnabled ? "policy-btn-on" : "policy-btn-off")"
                                                    title="@(p.RemindersEnabled ? "Reminders on — click to disable" : "Reminders off — click to enable")">
                                                🔔
                                            </button>
                                        </form>
                                        <form method="post" action="/profile/policies/delete/@p.Id" style="display:inline"
                                              onsubmit="return confirm('Remove @p.PolicyName from your policies?')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="policy-btn policy-btn-del" title="Remove policy">×</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </section>

            @* ── Quote history ─────────────────────────────────────────────── *@
            <section class="profile-section" id="quotesSection">
                <h2 class="profile-section-title">Quote History</h2>

                @if (!quotes.Any())
                {
                    <div class="profile-empty-state">
                        <div class="profile-empty-icon">📋</div>
                        <p>No quotes requested yet.</p>
                        <a href="/" class="profile-link-btn">Browse plans →</a>
                    </div>
                }
                else
                {
                    <div class="quotes-list">
                        @foreach (var q in quotes)
                        {
                            <div class="quote-row">
                                <div class="quote-row-info">
                                    <div class="quote-row-plan">@q.PlanName</div>
                                    <div class="quote-row-meta">@q.ProviderName · @q.InsuranceType · KES @q.MonthlyPremium.ToString("N0")/mo</div>
                                    <div class="quote-row-date">@q.RequestedAt.ToString("d MMM yyyy")</div>
                                </div>
                                <span class="quote-status quote-status-@q.Status.ToString().ToLower()">@q.Status</span>
                            </div>
                        }
                    </div>
                }
            </section>

        </div>
    </div>
</div>

@* ── Add Policy Modal ─────────────────────────────────────────────────────── *@
<div id="addPolicyModal" class="a-modal-overlay" style="display:none" onclick="if(event.target===this)this.style.display='none'">
    <div class="a-modal" style="width:520px">
        <h3 class="a-modal-title">Register a Policy</h3>
        <p style="font-size:13px;color:#64748b;margin:-8px 0 20px">Track an existing policy — set renewal reminders and keep everything in one place.</p>
        <form method="post" action="/profile/policies/add">
            @Html.AntiForgeryToken()
            <div class="a-form-grid">
                <div class="a-form-group a-span-2">
                    <label class="a-label">Policy / Plan Name <span style="color:#e11d48">*</span></label>
                    <input class="a-input" name="policyName" placeholder="e.g. Jubilee Comprehensive Motor" required maxlength="200" />
                </div>
                <div class="a-form-group">
                    <label class="a-label">Provider <span style="color:#e11d48">*</span></label>
                    <input class="a-input" name="providerName" placeholder="e.g. Jubilee Insurance" required maxlength="200" />
                </div>
                <div class="a-form-group">
                    <label class="a-label">Cover Type</label>
                    <select class="a-select" name="insuranceType">
                        <option value="">— select —</option>
                        @foreach (var t in Enum.GetValues<InsuranceType>())
                        {
                            <option value="@t">@t</option>
                        }
                    </select>
                </div>
                <div class="a-form-group">
                    <label class="a-label">Policy Number</label>
                    <input class="a-input" name="policyNumber" placeholder="Optional" maxlength="100" />
                </div>
                <div class="a-form-group">
                    <label class="a-label">Monthly Premium (KES)</label>
                    <input class="a-input" name="monthlyPremium" type="number" step="0.01" min="0" placeholder="0.00" />
                </div>
                <div class="a-form-group">
                    <label class="a-label">Start Date</label>
                    <input class="a-input" name="startDate" type="date" value="@DateTime.UtcNow.ToString("yyyy-MM-dd")" />
                </div>
                <div class="a-form-group">
                    <label class="a-label">Renewal Date <span style="color:#e11d48">*</span></label>
                    <input class="a-input" name="renewalDate" type="date" required
                           value="@DateTime.UtcNow.AddYears(1).ToString("yyyy-MM-dd")" />
                </div>
                <div class="a-form-group a-center-self">
                    <label class="a-checkbox-label">
                        <input type="checkbox" name="remindersEnabled" value="true" checked />
                        Email reminders before renewal
                    </label>
                </div>
            </div>
            <div class="a-modal-actions">
                <button type="button" class="a-btn-ghost" onclick="document.getElementById('addPolicyModal').style.display='none'">Cancel</button>
                <button type="submit" class="a-btn-primary">Save Policy</button>
            </div>
        </form>
    </div>
</div>
