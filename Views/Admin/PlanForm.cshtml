@model Insurance_Hub.Models.InsurancePlan
@using Insurance_Hub.Models

@{
    var isNew = Model.Id == 0;
    var action = isNew ? "/admin/plans/create" : $"/admin/plans/{Model.Id}/edit";
}

<div class="a-page-header">
    <div>
        <h1 class="a-page-title">@(isNew ? "New Plan" : "Edit Plan")</h1>
    </div>
    <a href="/admin/plans" class="a-btn-ghost">← Back</a>
</div>

<div class="a-form-card">
    <form method="post" action="@action">
        @Html.AntiForgeryToken()
        @if (!isNew)
        {
            <input type="hidden" name="Id" value="@Model.Id" />
        }

        <div class="a-form-grid">
            <div class="a-form-group a-span-2">
                <label class="a-label">Plan Name</label>
                <input class="a-input" name="PlanName" value="@Model.PlanName" required maxlength="200" />
            </div>
            <div class="a-form-group a-span-2">
                <label class="a-label">Description</label>
                <textarea class="a-textarea" name="Description" rows="2" maxlength="500">@Model.Description</textarea>
            </div>

            <div class="a-form-group">
                <label class="a-label">Type</label>
                <select class="a-select" name="Type">
                    @foreach (var t in Enum.GetValues<InsuranceType>())
                    {
                        if (Model.Type == t) { <option value="@t" selected>@t</option> }
                        else                 { <option value="@t">@t</option> }
                    }
                </select>
            </div>
            <div class="a-form-group">
                <label class="a-label">Tier</label>
                <select class="a-select" name="Tier">
                    @foreach (var t in Enum.GetValues<PlanTier>())
                    {
                        if (Model.Tier == t) { <option value="@t" selected>@t</option> }
                        else                 { <option value="@t">@t</option> }
                    }
                </select>
            </div>

            <div class="a-form-group">
                <label class="a-label">Provider</label>
                <select class="a-select" name="ProviderId">
                    @foreach (var pv in (List<Provider>)ViewBag.Providers)
                    {
                        if (Model.ProviderId == pv.Id) { <option value="@pv.Id" selected>@pv.Name</option> }
                        else                           { <option value="@pv.Id">@pv.Name</option> }
                    }
                </select>
            </div>
            <div class="a-form-group">
                <label class="a-label">Rating (0–5)</label>
                <input class="a-input" name="Rating" type="number" step="0.1" min="0" max="5" value="@Model.Rating" />
            </div>

            <div class="a-form-group">
                <label class="a-label">Monthly Premium (KES)</label>
                <input class="a-input" name="MonthlyPremium" type="number" step="0.01" min="0" value="@Model.MonthlyPremium" required />
            </div>
            <div class="a-form-group">
                <label class="a-label">Coverage Limit (KES, 0 = unlimited)</label>
                <input class="a-input" name="CoverageLimit" type="number" step="0.01" min="0" value="@Model.CoverageLimit" />
            </div>
            <div class="a-form-group">
                <label class="a-label">Deductible (KES)</label>
                <input class="a-input" name="Deductible" type="number" step="0.01" min="0" value="@Model.Deductible" />
            </div>
            <div class="a-form-group a-center-self">
                <label class="a-checkbox-label">
                    <input type="checkbox" name="IsPopular" value="true" @(Model.IsPopular ? "checked" : "") />
                    Mark as Popular
                </label>
            </div>

            <div class="a-form-group a-span-2">
                <label class="a-label">Features (pipe-separated: Feature 1|Feature 2|Feature 3)</label>
                <textarea class="a-textarea" name="Features" rows="3" maxlength="2000">@Model.Features</textarea>
            </div>
        </div>

        <div class="a-form-actions">
            <a href="/admin/plans" class="a-btn-ghost">Cancel</a>
            <button type="submit" class="a-btn-primary">@(isNew ? "Create Plan" : "Save Changes")</button>
        </div>
    </form>
</div>
