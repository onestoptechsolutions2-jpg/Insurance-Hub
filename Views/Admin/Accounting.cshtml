@model List<Insurance_Hub.Models.UserPolicy>
@using Insurance_Hub.Models

@{
    var periodMonth = ViewBag.PeriodMonth as string;
}

<div class="a-page-header">
    <div>
        <h1 class="a-page-title">Accounting</h1>
        <p class="a-page-sub">Monthly commission &amp; premium reconciliation — a record of what's happened, not a forecast.</p>
    </div>
    <div class="a-filter-bar">
        <form method="get" style="display:flex;gap:8px;align-items:center">
            <input type="month" name="month" class="a-input" value="@periodMonth" onchange="this.form.submit()" />
        </form>
        <a href="/admin/accounting/ledger" class="a-btn-ghost">Full Ledger</a>
    </div>
</div>

<div class="a-stats-row">
    <div class="a-stat-tile">
        <div class="a-stat-label">Expected Commission</div>
        <div class="a-stat-value">KES @(((decimal)ViewBag.ExpectedCommissionTotal).ToString("N0"))</div>
    </div>
    <div class="a-stat-tile">
        <div class="a-stat-label">Commission Received</div>
        <div class="a-stat-value">KES @(((decimal)ViewBag.ReceivedCommissionTotal).ToString("N0"))</div>
    </div>
    <div class="a-stat-tile">
        <div class="a-stat-label">Expected Premiums</div>
        <div class="a-stat-value">KES @(((decimal)ViewBag.ExpectedPremiumTotal).ToString("N0"))</div>
    </div>
    <div class="a-stat-tile">
        <div class="a-stat-label">Premiums Collected</div>
        <div class="a-stat-value">KES @(((decimal)ViewBag.CollectedPremiumTotal).ToString("N0"))</div>
    </div>
</div>

@if (!Model.Any())
{
    <div class="a-empty">No policies yet.</div>
}
else
{
    <div class="a-table-wrap">
        <table class="a-table">
            <thead>
                <tr>
                    <th>Client</th>
                    <th>Policy</th>
                    <th>Monthly Premium</th>
                    <th>Commission Rate</th>
                    <th>Expected Commission</th>
                    <th>This Month</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    var expectedCommission = p.MonthlyPremium * (p.CommissionRate ?? 0) / 100;
                    var transactions = ((List<Transaction>)ViewBag.TransactionsThisMonth)
                        .Where(t => t.PolicyId == p.Id).ToList();

                    <tr>
                        <td>
                            <div class="a-cell-primary">@p.Client?.FullName</div>
                            <div class="a-cell-sub">@p.Client?.Email</div>
                        </td>
                        <td>
                            <div class="a-cell-primary">@p.PolicyName</div>
                            <div class="a-cell-sub">@p.ProviderName</div>
                        </td>
                        <td>KES @p.MonthlyPremium.ToString("N0")</td>
                        <td>@(p.CommissionRate is null ? "—" : $"{p.CommissionRate}%")</td>
                        <td>KES @expectedCommission.ToString("N0")</td>
                        <td class="a-cell-sub">
                            @if (!transactions.Any())
                            {
                                <span>—</span>
                            }
                            else
                            {
                                @foreach (var t in transactions)
                                {
                                    <div>@(t.Type == TransactionType.CommissionReceived ? "Comm." : "Prem.") KES @t.Amount.ToString("N0")</div>
                                }
                            }
                        </td>
                        <td>
                            <div class="a-row-actions">
                                <button class="a-btn-sm" onclick="openRecordModal(@p.Id, 'CommissionReceived', @expectedCommission)">+ Commission</button>
                                <button class="a-btn-sm" onclick="openRecordModal(@p.Id, 'PremiumCollected', @p.MonthlyPremium)">+ Premium</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<!-- Record transaction modal -->
<div id="recordModal" class="a-modal-overlay" style="display:none">
    <div class="a-modal">
        <h3 class="a-modal-title">Record Transaction</h3>
        <form id="recordForm" method="post" action="/admin/accounting/record">
            @Html.AntiForgeryToken()
            <input type="hidden" name="policyId" id="recordPolicyId" />
            <input type="hidden" name="periodMonth" value="@periodMonth" />
            <div class="a-form-group">
                <label class="a-label">Type</label>
                <select name="type" id="recordType" class="a-select">
                    <option value="CommissionReceived">Commission Received</option>
                    <option value="PremiumCollected">Premium Collected</option>
                </select>
            </div>
            <div class="a-form-group">
                <label class="a-label">Amount (KES)</label>
                <input type="number" step="0.01" name="amount" id="recordAmount" class="a-input" required />
            </div>
            <div class="a-form-group">
                <label class="a-label">Notes</label>
                <textarea name="notes" class="a-textarea" rows="2" placeholder="Optional"></textarea>
            </div>
            <div class="a-modal-actions">
                <button type="button" class="a-btn-ghost" onclick="closeRecordModal()">Cancel</button>
                <button type="submit" class="a-btn-primary">Record</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    function openRecordModal(policyId, type, amount) {
        document.getElementById('recordPolicyId').value = policyId;
        document.getElementById('recordType').value = type;
        document.getElementById('recordAmount').value = amount.toFixed(2);
        document.getElementById('recordModal').style.display = 'flex';
    }
    function closeRecordModal() {
        document.getElementById('recordModal').style.display = 'none';
    }
    document.getElementById('recordModal').addEventListener('click', function(e) {
        if (e.target === this) closeRecordModal();
    });
</script>
}
