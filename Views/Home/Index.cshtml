@model List<Insurance_Hub.Models.InsurancePlan>
@using Insurance_Hub.Models
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager

@{
    var activeType     = ViewBag.ActiveType as string ?? "All";
    var activeProvider = ViewBag.ActiveProvider as string ?? "All";
    var providers      = ViewBag.Providers as List<string> ?? new List<string>();

    var aisles = new[]
    {
        new { Name = "All",         Icon = "🏪", Label = "All Plans"   },
        new { Name = "Life",        Icon = "🫀", Label = "Life"        },
        new { Name = "Health",      Icon = "🏥", Label = "Health"      },
        new { Name = "Motor",       Icon = "🚗", Label = "Motor"       },
        new { Name = "Home",        Icon = "🏠", Label = "Home"        },
        new { Name = "Travel",      Icon = "✈️", Label = "Travel"      },
        new { Name = "Business",    Icon = "🏢", Label = "Business"    },
        new { Name = "Agriculture", Icon = "🌾", Label = "Agriculture" },
        new { Name = "Micro",       Icon = "📱", Label = "Micro"       },
    };
}

@* ── Toast ─────────────────────────────────────────────────────────────── *@
@if (TempData["QuoteSuccess"] is string ok)
{
    <div class="toast toast-success" id="toast">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
        <span>@ok</span>
        <button class="toast-close" onclick="this.parentElement.remove()">×</button>
    </div>
}
@if (TempData["QuoteError"] is string err)
{
    <div class="toast toast-error" id="toast-err">
        <span>@err</span>
        <button class="toast-close" onclick="this.parentElement.remove()">×</button>
    </div>
}

@* ── Search bar ─────────────────────────────────────────────────────────── *@
<div class="sm-search-wrap">
    <div class="sm-search-icon">🔍</div>
    <input id="searchBox" class="sm-search" type="text"
           placeholder="Search plans, providers or cover type…" autocomplete="off" />
    @if (activeType != "All" || activeProvider != "All")
    {
        <a href="/" class="sm-search-clear" title="Clear filters">×</a>
    }
</div>

@* ── Aisles ─────────────────────────────────────────────────────────────── *@
<div class="sm-aisles">
    @foreach (var a in aisles)
    {
        var href   = a.Name == "All" ? Url.Action("Index","Home") : Url.Action("Index","Home", new { type = a.Name });
        var active = a.Name == activeType;
        <a href="@href" class="sm-aisle @(active ? "sm-aisle-active" : "")">
            <span class="sm-aisle-icon">@a.Icon</span>
            <span class="sm-aisle-label">@a.Label</span>
        </a>
    }
</div>

@* ── Provider strip ─────────────────────────────────────────────────────── *@
@if (providers.Any())
{
    <div class="sm-provider-strip">
        @{
            var allHref = activeType == "All" ? Url.Action("Index","Home") : Url.Action("Index","Home", new { type = activeType });
        }
        <a href="@allHref" class="sm-provider-pill @(activeProvider == "All" ? "active" : "")">All providers</a>
        @foreach (var p in providers)
        {
            var href = activeType == "All"
                ? Url.Action("Index","Home", new { provider = p })
                : Url.Action("Index","Home", new { type = activeType, provider = p });
            <a href="@href" class="sm-provider-pill @(p == activeProvider ? "active" : "")">@p</a>
        }
    </div>
}

@* ── Results header ─────────────────────────────────────────────────────── *@
<div class="sm-results-header">
    <span class="sm-results-count" id="resultsCount">@Model.Count plan@(Model.Count != 1 ? "s" : "")</span>
    @if (activeType != "All")
    {
        <span class="sm-results-label">in @activeType</span>
    }
    @if (activeProvider != "All")
    {
        <span class="sm-results-label">· @activeProvider</span>
    }
</div>

@* ── Product shelf ──────────────────────────────────────────────────────── *@
<div class="sm-shelf" id="shelf">
    @if (!Model.Any())
    {
        <div class="sm-empty">
            <div style="font-size:48px;margin-bottom:12px;">🔍</div>
            <p>No plans found. <a href="/" class="profile-link">Browse all →</a></p>
        </div>
    }

    @foreach (var plan in Model)
    {
        var stars       = (int)Math.Round(plan.Rating);
        var topFeatures = plan.FeatureList.Take(4).ToList();

        <div class="sm-card insurance-plan" data-type="@plan.Type" data-provider="@plan.Provider?.Name">

            @* Provider + Popular *@
            <div class="sm-card-top">
                <span class="sm-card-provider">@plan.Provider?.Name</span>
                @if (plan.IsPopular) { <span class="sm-popular">🔥 Popular</span> }
            </div>

            @* Plan name *@
            <div class="sm-card-name">@plan.PlanName</div>

            @* Type badge *@
            <div class="sm-card-type">@plan.Type · @plan.Tier</div>

            @* Stars *@
            <div class="sm-stars">
                @for (int i = 1; i <= 5; i++)
                {
                    <span class="@(i <= stars ? "star-filled" : "star-empty")">★</span>
                }
                <span class="sm-rating">@plan.Rating.ToString("0.0")</span>
            </div>

            @* Price — the hero *@
            <div class="sm-price">
                <span class="sm-price-currency">KES</span>
                <span class="sm-price-amount">@plan.MonthlyPremium.ToString("N0")</span>
                <span class="sm-price-period">/mo</span>
            </div>

            @if (plan.CoverageLimit > 0)
            {
                <div class="sm-coverage">Cover up to KES @plan.CoverageLimit.ToString("N0")</div>
            }
            else
            {
                <div class="sm-coverage">Unlimited cover</div>
            }

            @* Features *@
            <ul class="sm-features">
                @foreach (var f in topFeatures)
                {
                    <li>@f</li>
                }
            </ul>

            @* Actions *@
            <div class="sm-card-actions">
                @if (SignInManager.IsSignedIn(User))
                {
                    <button class="sm-btn-quote quote-btn"
                            data-plan-id="@plan.Id"
                            data-plan="@plan.PlanName"
                            data-provider="@plan.Provider?.Name"
                            data-premium="@plan.MonthlyPremium"
                            data-type="@plan.Type"
                            data-tier="@plan.Tier"
                            data-coverage="@plan.CoverageLimit"
                            data-features="@plan.Features">
                        Get Quote
                    </button>
                }
                else
                {
                    <a href="/Identity/Account/Login" class="sm-btn-quote">Get Quote</a>
                }
                <a href="@Url.Action("Details","Home", new { id = plan.Id })" class="sm-btn-details">Details →</a>
            </div>

        </div>
    }
</div>

@* ── Quote modal (unchanged logic) ──────────────────────────────────────── *@
<div id="quoteModal" class="modal">
    <div class="modal-content">
        <span id="closeForm" class="close">&times;</span>
        <div class="modal-plan-badge" id="modalBadge"></div>
        <h2 style="margin:8px 0 4px;">Get a Quote</h2>
        <p class="modal-plan-name" id="selectedPlan"></p>
        <p class="modal-provider" id="modalProvider"></p>
        <p class="modal-price" id="modalPrice"></p>
        <form id="quoteForm" asp-action="RequestQuote" asp-controller="Home" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="planId"         id="hiddenPlanId" />
            <input type="hidden" name="planName"       id="hiddenPlanName" />
            <input type="hidden" name="planTier"       id="hiddenTier" />
            <input type="hidden" name="providerName"   id="hiddenProvider" />
            <input type="hidden" name="monthlyPremium" id="hiddenPremium" />
            <input type="hidden" name="coverageLimit"  id="hiddenCoverage" />
            <input type="hidden" name="insuranceType"  id="hiddenType" />
            <input type="hidden" name="features"       id="hiddenFeatures" />
            <div class="modal-field">
                <label for="fullName">Full Name</label>
                <input type="text" id="fullName" name="fullName" placeholder="Jane Wanjiku" required />
            </div>
            <div class="modal-field">
                <label for="emailInput">Email Address</label>
                <input type="email" id="emailInput" name="email" placeholder="jane@example.com" required />
            </div>
            <button type="submit" class="btn-primary full" style="margin-top:4px;">Send Quote Request →</button>
        </form>
    </div>
</div>
