# ── Insurance Hub — Environment Variables ────────────────────────────────────
# Copy to .env for local docker compose, or paste into Coolify's env var panel.
# Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# For Coolify: copy the internal connection string from your Coolify PostgreSQL resource
DATABASE_URL=Host=db;Port=5432;Database=InsuranceHub;Username=postgres;Password=changeme

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# Gmail example: use an App Password (not your main password)
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_SSL=true
SMTP_SENDER_EMAIL=noreply@yourdomain.com
SMTP_SENDER_NAME=InsuranceHub
SMTP_PASSWORD=your-app-password

# The inbox that receives all quote request notifications
AGENT_EMAIL=agent@yourdomain.com

# ── App image (Coolify compose only) ──────────────────────────────────────────
APP_IMAGE=ghcr.io/yourusername/insurance-hub:latest
