{
  // Set to "PostgreSQL" or "SqlServer" to switch providers.
  // Remember to re-run migrations when switching.
  "DatabaseProvider": "PostgreSQL",

  "ConnectionStrings": {
    "PostgreSQL": "Host=localhost;Port=5432;Database=InsuranceHub;Username=postgres;Password=",
    "SqlServer": "Server=(localdb)\\mssqllocaldb;Database=InsuranceHub;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  // ── Email / SMTP ──────────────────────────────────────────────────────────
  // Fill in your SMTP credentials. Leave SmtpHost blank to disable sending
  // (requests still save to DB; a warning is logged instead).
  "EmailSettings": {
    "SmtpHost":       "",
    "SmtpPort":       587,
    "UseSsl":         true,
    "SenderEmail":    "noreply@insurancehub.com",
    "SenderName":     "InsuranceHub",
    "SenderPassword": "",
    "AgentEmail":     "agent@insurancehub.com"
  }
}
